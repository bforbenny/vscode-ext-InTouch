Object Type: ActiveX
Object Name: axSQL_Logger

ActiveX Script: OnDataReady

  Comment: Logs process data to SQL database on each scan cycle.

  DIM bolConn   AS Discrete;
  DIM strConn   AS Message;
  DIM intResult AS Integer;

  strConn = "DSN=ProcessDB;UID=logger;PWD=log123;";
  bolConn = SQLConnect("LogDB", strConn);

  IF bolConn THEN
      SQLInsert("LogDB", "ProcessLog", "TagName, Value, Timestamp",
                "'Reactor1.Temperature', " +
                StringFromReal(Reactor1.Temperature.Value, "%8.3f") + ", " +
                "'" + $DateTime + "'");
      SQLDisconnect("LogDB");
  ELSE
      LogMessage("ERROR: Cannot connect to SQL - " + SQLErrorMsg("LogDB"));
  ENDIF;

================================================================================

Object Type: Button
Object Name: btn_RecipeSave

QuickFunction Script: SaveCurrentRecipe

  Comment: Saves active recipe parameters to disk.

  DIM strRecipeName AS Message;
  DIM intResult     AS Integer;

  strRecipeName = "Batch_" + StringFromIntg($Day, 10) + "_" + StringFromIntg($Month, 10);

  intResult = RecipeSave(strRecipeName, "ReactorRecipeUnit");

  IF intResult == 0 THEN
      LogMessage("Recipe saved: " + strRecipeName);
  ELSE
      LogMessage("ERROR saving recipe: " + strRecipeName);
  ENDIF;

